# ================================================================================
# SUPABASE CONFIGURATION
# ================================================================================
# Get these values from Supabase Dashboard > Settings > API
#
# Steps:
# 1. Go to https://supabase.com and sign in
# 2. Open your project
# 3. Click "Settings" in the left sidebar
# 4. Click "API"
# 5. Copy the values below:

# Your Supabase project URL
# Example: https://abcdefgh1234.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon key (starts with 'eyJ')
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=your-anon-key-here

# ================================================================================
# APP CONFIGURATION
# ================================================================================
APP_ENV=development
APP_NAME=REXI

# ================================================================================
# FEATURE FLAGS
# ================================================================================
ENABLE_MESSAGING=true
ENABLE_NOTIFICATIONS=true
ENABLE_FAVORITES=true

# ================================================================================
# Optional: Database Connection String (for advanced use)
# ================================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/rexi
